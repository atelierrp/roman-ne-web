---
/**
 * Natural aspect ratio: no cropping. Optional imgWidth/imgHeight (pixels) for CLS hints.
 */
const {
  src = "",
  alt = "",
  caption = "",
  figureClass = "",
  emptyLabel = "Image placeholder",
  imgWidth,
  imgHeight,
  srcset = "",
  sizes = "",
  loading = "lazy",
  fetchPriority,
} = Astro.props;
---

<figure class:list={["reveal-image", "reveal-image--intrinsic", figureClass]}>
  {
    src ? (
      <>
        <div class="reveal-image__media">
          <img
            class="reveal-image__img"
            src={src}
            alt={alt}
            {...(srcset ? { srcset } : {})}
            {...(sizes ? { sizes } : {})}
            {...(imgWidth != null ? { width: imgWidth } : {})}
            {...(imgHeight != null ? { height: imgHeight } : {})}
            loading={loading}
            {...(fetchPriority ? { fetchpriority: fetchPriority } : {})}
            decoding="async"
          />
        </div>
        {caption ? (
          <figcaption class="reveal-image__caption">{caption}</figcaption>
        ) : null}
      </>
    ) : (
      <div
        class="block__placeholder"
        role="img"
        aria-label={alt || emptyLabel}
      >
        {emptyLabel}
      </div>
    )
  }
</figure>
