---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/blocks/Hero.astro";
import { currentProject } from "../data/current.js";
import "../styles/global.css";
---

<BaseLayout
  title="Hardcore yoga nidra — Roman Ne"
  description="Small group sessions in Zürich. Voice, sound, attention. 60 min. Message on WhatsApp."
>
  <main class="hcyn">
    <article class="bio-layout hcyn__layout">
      <div class="bio-layout__column">
        <div class="bio-layout__intro hcyn__intro">
          <h1 class="hcyn__title">
            <span>hardcore</span>
            <span>yoga</span>
            <span>nidra</span>
          </h1>
          <div class="hcyn__schedule">
            <p>Sat 6/6 — 11:00</p>
            <p>Sat 13/6 — 11:00</p>
            <p>Sat 20/6 — 11:00</p>
          </div>
          <p class="hcyn__cta-wrap">
            <a
              class="hcyn__cta"
              href="https://forms.gle/Y2U8zsY1VhuiqLAAA"
              target="_blank"
              rel="noopener noreferrer"
            >
              → registration form
            </a>
          </p>
          <div class="hcyn__register-note" role="note">
            <p>
              *Additional sessions may be possible depending on availability. If
              none of the listed dates work for you, mention it in the form.
            </p>
          </div>
        </div>

        <div class="bio-layout__image hcyn__meta">
          <section class="hcyn__details" aria-label="Session and studio">
            <div class="hcyn__session">
              <p>60 min closed-eyes listening session</p>
              <p>lying down, no movement</p>
              <p>small-group session</p>
              <p>in English</p>
              <p><br /></p>
              <p>20 CHF</p>
              <p>HCYN Studio</p>
              <p>Zypressenstrasse 60, Zurich</p>
              <p>077 266 58 32</p>
            </div>
            <div class="hcyn__studio">
              <p>
                <a
                  href="https://www.instagram.com/hardcoreyoganidra/"
                  target="_blank"
                  rel="noopener noreferrer">@hardcoreyoganidra ↗</a
                >
              </p>
              <p>
                <a href="/" target="_blank" rel="noopener noreferrer"
                  >roman-ne.com ↗</a
                >
              </p>
            </div>
          </section>
        </div>
      </div>

      <div class="bio-layout__aside hcyn__video">
        <Hero
          variant="contained"
          mediaKind="youtube"
          youtubeUrl={currentProject.youtubeUrl}
          alt="Black Square — hardcore yoga nidra"
        />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .hcyn {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    margin: 0;
    min-height: 100dvh;
    color: var(--color-text);
    background: #000;
    padding-top: calc(env(safe-area-inset-top, 0px) + 1rem);
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 2rem);
  }

  .hcyn a {
    color: inherit;
    text-decoration: none;
  }

  .hcyn a:hover {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .bio-layout.hcyn__layout > .bio-layout__column {
    gap: calc(var(--bio-row-gap) / 2.5 * 1.5);
  }

  .hcyn__title {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: 0.92;
  }

  .hcyn__title span {
    display: block;
    font-family: var(--font-family-wide-bold);
    font-size: clamp(2.25rem, 7.5vw, 4.75rem);
    letter-spacing: -0.02em;
    text-transform: lowercase;
  }

  @media (max-width: 768px) {
    .hcyn__title span {
      font-size: clamp(2.5rem, calc(90vw / 6), 6rem);
    }
  }

  .hcyn__schedule {
    margin-top: clamp(1rem, 3vw, 1.5rem);
  }

  .hcyn__schedule p {
    margin: 0;
    line-height: inherit;
  }

  .hcyn__schedule p + p {
    margin-top: calc((var(--line-height-body) - 1) * 1em);
  }

  .hcyn__cta-wrap {
    margin: clamp(1rem, 3vw, 1.5rem) 0 0;
  }

  .hcyn__register-note {
    margin: 0.55em 0 0;
    max-width: 24em;
    font-size: clamp(0.68rem, 2.2vw, 0.76rem);
    line-height: inherit;
    opacity: 0.68;
  }

  .hcyn__register-note p {
    margin: 0;
  }

  .hcyn__register-note p + p {
    margin-top: 0.35em;
  }

  .hcyn__video :global(.block--hero) {
    margin: 0;
  }

  .hcyn__video :global(.block--hero--contained .block--hero__media) {
    max-width: 100%;
  }

  .hcyn__details {
    margin: 0;
  }

  .hcyn__session,
  .hcyn__studio {
    margin: 0;
  }

  .hcyn__session p,
  .hcyn__studio p {
    margin: 0;
    line-height: inherit;
  }

  .hcyn__session p + p,
  .hcyn__studio p + p {
    margin-top: calc((var(--line-height-body) - 1) * 1em);
  }

  .hcyn__studio {
    margin-top: clamp(1.5rem, 4vw, 2.25rem);
  }
</style>
