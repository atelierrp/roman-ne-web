---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageRow from "../components/blocks/ImageRow.astro";
import SiteNav from "../components/SiteNav.astro";
import "../styles/global.css";

const introEntry = await getEntry("bio", "intro");
const asideEntry = await getEntry("bio", "aside");
if (!introEntry) throw new Error("Missing content collection entry: bio/intro");
if (!asideEntry) throw new Error("Missing content collection entry: bio/aside");

const { data: introMeta } = introEntry;
const { Content: IntroContent } = await render(introEntry);
const { Content: AsideContent } = await render(asideEntry);

const title = introMeta.title ?? "Roman Ne — Bio";
const description = introMeta.description ?? "";
const imageSrc = introMeta.imageSrc;
const imageAlt = introMeta.imageAlt ?? "";
---

<BaseLayout title={title} description={description}>
  <main class="site-main">
    <SiteNav activeId="bio" />
    <div class="site-content" id="site-content">
      <article class="bio-layout">
        <div class="bio-layout__column">
          <div class="bio-layout__intro">
            <div class="bio-md bio-md--intro">
              <IntroContent />
            </div>
          </div>
          <nav class="bio-layout__links" aria-label="Project links">
            <h2 class="bio-layout__links__title">LINKS</h2>
            <ul class="bio-layout__links__list">
              <li>
                <a href="/hardcoreyoganidra">Hardcore Yoga Nidra</a>
              </li>
              <li>
                <a href="/adjustmentstonothing">Adjustments to Nothing</a>
              </li>
              <li>
                <a href="/collaboration-igja">IGJA collaborations</a>
              </li>
              <li>
                <a
                  class="external-link--arrow"
                  href="https://fiordmoss.bandcamp.com/album/kingdom-come"
                  target="_blank"
                  rel="noopener noreferrer">Fiordmoss</a
                >
              </li>
              <li>
                <a
                  class="external-link--arrow"
                  href="https://www.acudmachtneu.de"
                  target="_blank"
                  rel="noopener noreferrer">Acud Macht Neu</a
                >
              </li>
            </ul>
          </nav>
          {
            imageSrc && (
              <div class="bio-layout__image">
                <ImageRow
                  images={[
                    {
                      src: imageSrc,
                      alt: imageAlt,
                      orientation: "vertical",
                    },
                  ]}
                />
              </div>
            )
          }
        </div>
        <div class="bio-layout__aside">
          <div class="bio-md bio-md--aside">
            <AsideContent />
          </div>
        </div>
      </article>
    </div>
  </main>
</BaseLayout>
